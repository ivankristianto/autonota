{
  "name": "autonota",
  "version": "0.1.0",
  "description": "CLI to transcribe YouTube audio and summarize transcripts",
  "type": "module",
  "bin": {
    "autonota": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.lint.json",
    "lint": "npm run format:check && eslint src tests",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "release": "bash scripts/release.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "cli",
    "transcription",
    "whisper",
    "youtube",
    "summary"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "listr2": "^9.0.5",
    "openai": "^6.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  }
}
