{
  "name": "nota",
  "version": "0.1.0",
  "description": "CLI to transcribe YouTube audio and summarize transcripts",
  "type": "module",
  "bin": {
    "nota": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "transcription",
    "whisper",
    "youtube",
    "summary"
  ],
  "license": "MIT",
  "dependencies": {
